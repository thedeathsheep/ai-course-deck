---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResourceRow from "../../components/ResourceRow.astro";
import { groupResourcesByCategory, sortResourcesByPriority } from "../../lib/site-data.mjs";
import "../../styles/resources.css";

const resources = sortResourcesByPriority(await getCollection("resources"));
const grouped = groupResourcesByCategory(resources);
const featured = resources.filter((item) => item.data.priority === "S").slice(0, 6);
const categoryIds = Object.fromEntries(
  grouped.map((group, index) => [group.category, `category-${index + 1}`]),
);

const categoryDescriptions = {
  "免费 AI 工具": "优先面向大陆用户、可直接体验或有免费额度的通用工具。",
  "提示词资料库": "适合课堂现场点名、课后直接照着学的提示词与方法资源。",
  "热门玩法与教程": "围绕 OpenClaw、Seedance 2.0、即梦、可灵、海螺等玩法的入口。",
  "飞书与知识库": "社区沉淀最强的一类外部资料，适合继续深挖。",
  "AI 通识课程": "帮助普通学习者从工具使用回到 AI 认知本身。",
};
---

<BaseLayout title="AI 资源库">
  <main class="site-shell">
    <div class="page-shell">
      <nav class="site-nav">
        <div class="site-nav__brand">
          <span class="site-nav__brand-mark"></span>
          AI Resource Library
        </div>
        <div class="site-nav__links">
          <a href="/">首页</a>
          <a href="/slides/">演讲页</a>
        </div>
      </nav>

      <section class="resources-hero">
        <div>
          <span class="eyebrow">课后精选资源</span>
          <h1>把“别人已经整理好的资源”精选成一张可继续追下去的地图。</h1>
          <p>
            这一页不给学员堆链接，而是先给路标、再给入口、再告诉他们为什么值得看。
          </p>
        </div>

        <aside class="resources-panel">
          <h2>使用方式</h2>
          <div class="resource-summary-grid">
            <div>
              <h3>先看 S 级</h3>
              <p>适合立即收藏，能直接带来上手感或认知框架。</p>
            </div>
            <div>
              <h3>再按分类</h3>
              <p>根据当前需求去工具、提示词、玩法或通识课程里继续找。</p>
            </div>
            <div>
              <h3>最后做 7 天路线</h3>
              <p>把一堆入口变成可执行的习惯，而不是只刷推荐。</p>
            </div>
          </div>
        </aside>
      </section>

      <section class="resources-quick-grid">
        <div class="resources-panel">
          <h3>精选总数</h3>
          <p>{resources.length} 条资源，按优先级与分类整理。</p>
        </div>
        <div class="resources-panel">
          <h3>适合谁</h3>
          <p>大众学习者、老师、家长、内容创作者和泛职场用户。</p>
        </div>
        <div class="resources-panel">
          <h3>访问提示</h3>
          <p>优先将大陆友好资源排在前面，需登录或外网的单独标注。</p>
        </div>
        <div class="resources-panel">
          <h3>推荐顺序</h3>
          <p>工具 → 提示词 → 热门玩法 → 通识课程 → 飞书知识库。</p>
        </div>
      </section>

      <section class="resources-panel">
        <h2>S 级先看</h2>
        <div class="resource-category-list">
          {featured.map((resource) => <ResourceRow resource={resource} />)}
        </div>
      </section>

      <nav class="resource-category-nav" aria-label="资源分类导航">
        {grouped.map((group) => <a href={`#${categoryIds[group.category]}`}>{group.category}</a>)}
        <a href="#learning-roadmap">7 天入门</a>
        <a href="#pitfalls">避坑建议</a>
      </nav>

      {
        grouped.map((group) => (
          <section id={categoryIds[group.category]} class="resource-category">
            <div class="resource-category__header">
              <h2>{group.category}</h2>
              <p>{categoryDescriptions[group.category]}</p>
            </div>

            <div class="resource-category-list">
              {group.resources.map((resource) => <ResourceRow resource={resource} />)}
            </div>
          </section>
        ))
      }

      <section id="learning-roadmap" class="resource-category">
        <div class="resource-category__header">
          <h2>7 天入门路径</h2>
          <p>适合课后跟着走一轮，先建立“能用”，再建立“能判断”。</p>
        </div>

        <div class="roadmap-grid">
          <div class="roadmap-step">
            <strong>Day 1</strong>
            <p>看一节通识课，先知道 AI 不是“工具列表”，而是新的协作方式。</p>
          </div>
          <div class="roadmap-step">
            <strong>Day 2</strong>
            <p>固定一个聊天工具，只练提问、总结、改写三件事。</p>
          </div>
          <div class="roadmap-step">
            <strong>Day 3</strong>
            <p>加一个搜索型 AI，理解“问答”和“检索”的分工。</p>
          </div>
          <div class="roadmap-step">
            <strong>Day 4</strong>
            <p>从提示词资料库抄 3 套模板，开始学背景、约束、格式。</p>
          </div>
          <div class="roadmap-step">
            <strong>Day 5</strong>
            <p>尝试图像生成，感受文生图提示词和文字问答的差别。</p>
          </div>
          <div class="roadmap-step">
            <strong>Day 6</strong>
            <p>尝试视频玩法，把“镜头、动作、风格、光线”练熟一轮。</p>
          </div>
          <div class="roadmap-step">
            <strong>Day 7</strong>
            <p>挑一个方向深挖：Agent、视频创作、知识库或系统课程。</p>
          </div>
        </div>
      </section>

      <section id="pitfalls" class="resource-category">
        <div class="resource-category__header">
          <h2>避坑与使用建议</h2>
          <p>学员最容易掉进的，不是不会用，而是太快相信或太快切换。</p>
        </div>

        <div class="resource-summary-grid">
          <div class="resources-panel">
            <h3>别把流畅当正确</h3>
            <p>越像人话的回答，越需要看来源、看事实、看边界。</p>
          </div>
          <div class="resources-panel">
            <h3>别一开始学五个工具</h3>
            <p>先固定两个，把习惯养出来，再扩展工具箱。</p>
          </div>
          <div class="resources-panel">
            <h3>别上传敏感信息</h3>
            <p>涉及隐私、合同、财务、医疗的内容，一律先脱敏再处理。</p>
          </div>
        </div>
      </section>

      <footer class="footnotes">
        <p>资源库优先收录官方页、GitHub 项目、课程页、飞书知识库和成熟社区整理站。</p>
        <p>AI 产品更新很快，免费额度、地区访问与入口可能变化，请以官方页面为准。</p>
      </footer>
    </div>
  </main>
</BaseLayout>
