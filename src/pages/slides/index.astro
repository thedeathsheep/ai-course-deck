---
import { getCollection, render } from "astro:content";

import SlideFrame from "../../components/SlideFrame.astro";
import { groupSlidesBySection, sortSlides } from "../../lib/site-data.mjs";
import "../../styles/global.css";
import "../../styles/slides-tokens.css";
import "../../styles/slides.css";
import "../../styles/slides-overrides.css";

const slideEntries = sortSlides(await getCollection("slides"));
const renderedSlides = await Promise.all(
  slideEntries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  })),
);

const sectionGroups = groupSlidesBySection(slideEntries);
let slideOffset = 0;
const sectionLinks = sectionGroups.map((group) => {
  const currentOffset = slideOffset;
  slideOffset += group.slides.length;
  return {
    section: group.section,
    startIndex: currentOffset,
    count: group.slides.length,
  };
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI 线下分享 slide</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="deck-page">
    <header class="deck-topbar">
      <div class="deck-topbar__brand">
        <span class="deck-topbar__brand-mark"></span>
        AI 不是更强的搜索，而是新的任务接口
      </div>

      <div class="deck-topbar__actions">
        <a href="/">返回首页</a>
        <a href="/resources/">资源库</a>
        <button id="section-nav-toggle" type="button">章节导航</button>
      </div>
    </header>

    <aside class="section-nav" id="section-nav" hidden>
      <h2>章节导航</h2>
      <ol>
        {
          sectionLinks.map((link) => (
            <li>
              <button type="button" data-slide-index={link.startIndex}>
                <span class="section-nav__item">
                  <strong>{link.section}</strong>
                  <span>{link.count} 张页面</span>
                </span>
              </button>
            </li>
          ))
        }
      </ol>
    </aside>

    <div class="reveal">
      <div class="slides">
        {
          renderedSlides.map(({ entry, Content }) => (
            <SlideFrame entry={entry} Content={Content} />
          ))
        }
      </div>
    </div>
    <script type="module" src="/slides-runtime.js"></script>
  </body>
</html>
