---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/resources.css";

const slideCount = (await getCollection("slides")).length;
const resourceCount = (await getCollection("resources")).length;
---

<BaseLayout title="AI 线下分享站点">
  <main class="site-shell">
    <div class="page-shell">
      <nav class="site-nav">
        <div class="site-nav__brand">
          <span class="site-nav__brand-mark"></span>
          AI Literacy Deck
        </div>
        <div class="site-nav__links">
          <a href="/slides/">进入演讲页</a>
          <a href="/resources/">进入资源库</a>
        </div>
      </nav>

      <section class="resources-hero">
        <div>
          <span class="eyebrow">线下分享主站</span>
          <h1>把 AI 通识课做成可演讲、可收藏、可上线的网页作品。</h1>
          <p>
            一个站点里同时交付 <strong>{slideCount}</strong> 张讲演页和 <strong>{resourceCount}</strong>
            条精选资源，保留真实截图、报告图表、引用来源与课后入口。
          </p>

          <div class="cta-row">
            <a class="button-link button-link--primary" href="/slides/">打开演讲 slide</a>
            <a class="button-link" href="/resources/">打开资源库</a>
          </div>
        </div>

        <aside class="resources-panel">
          <h2>这版站点解决什么问题</h2>
          <div class="resource-summary-grid">
            <div>
              <h3>现场可讲</h3>
              <p>Reveal.js 翻页、章节导航、备注视图，适合线下投屏。</p>
            </div>
            <div>
              <h3>素材真实</h3>
              <p>优先使用现有报告图、产品截图、品牌图标，而不是空占位。</p>
            </div>
            <div>
              <h3>后续可维护</h3>
              <p>内容用 MDX 管理，后续加页、换链接、补引用都更轻。</p>
            </div>
          </div>
        </aside>
      </section>
    </div>
  </main>
</BaseLayout>
