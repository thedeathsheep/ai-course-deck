---
interface Props {
  items?: string[];
}

const { items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <footer class="source-strip" aria-label="引用来源">
      <span class="source-strip__label">来源</span>
      <div class="source-strip__items">
        {items.map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </footer>
  )
}
